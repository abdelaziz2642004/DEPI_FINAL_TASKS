@model CinemaBooking.ViewModels.BookingViewModel
@{ ViewData["Title"] = "Book Tickets"; }

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-6">
            <div class="card text-white p-4">
                <h2 class="fw-bold mb-1" style="color:var(--gold)">Book Tickets</h2>
                <h5 class="mb-4 text-muted">@Model.Showtime.Movie?.Title</h5>

                <div class="row g-3 mb-4 p-3 rounded-2" style="background:rgba(255,255,255,0.04)">
                    <div class="col-6">
                        <div class="text-muted small">Cinema</div>
                        <div class="fw-500">@Model.Showtime.Hall?.Cinema?.Name</div>
                    </div>
                    <div class="col-6">
                        <div class="text-muted small">Hall</div>
                        <div class="fw-500">@Model.Showtime.Hall?.Name</div>
                    </div>
                    <div class="col-6">
                        <div class="text-muted small">Date & Time</div>
                        <div class="fw-500">@Model.Showtime.StartTime.ToLocalTime().ToString("MMM d, yyyy · h:mm tt")</div>
                    </div>
                    <div class="col-6">
                        <div class="text-muted small">Seats Available</div>
                        <div class="fw-bold text-success">@Model.Showtime.SeatsAvailable</div>
                    </div>
                </div>

                <form method="post" action="/Booking/Book">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ShowtimeId" value="@Model.ShowtimeId" />

                    <div class="mb-3">
                        <label class="form-label fw-500">Number of Seats</label>
                        <input type="number" name="NumberOfSeats" id="seatCount"
                               class="form-control bg-dark text-white border-secondary"
                               value="@Model.NumberOfSeats" min="1"
                               max="@Math.Min(Model.Showtime.SeatsAvailable, 20)"
                               oninput="updateTotal()" />
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <span class="text-danger small">@ViewData.ModelState["NumberOfSeats"]?.Errors.FirstOrDefault()?.ErrorMessage</span>
                        }
                    </div>

                    <div class="p-3 rounded-2 mb-4" style="background:rgba(245,166,35,0.1); border:1px solid rgba(245,166,35,0.3)">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="text-muted">Price per seat</span>
                            <span>$@Model.Showtime.TicketPrice.ToString("F2")</span>
                        </div>
                        <div class="d-flex justify-content-between fw-bold fs-5">
                            <span>Total</span>
                            <span style="color:var(--gold)" id="totalPrice">$@((Model.NumberOfSeats * Model.Showtime.TicketPrice).ToString("F2"))</span>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-gold w-100 py-2 fs-6 fw-bold">
                        <i class="bi bi-ticket-perforated me-2"></i>Confirm Booking
                    </button>
                    <a href="/Movies/Details/@Model.Showtime.MovieId" class="btn btn-outline-secondary w-100 mt-2">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const pricePerSeat = @Model.Showtime.TicketPrice;
        function updateTotal() {
            const seats = parseInt(document.getElementById('seatCount').value) || 0;
            document.getElementById('totalPrice').textContent = '$' + (seats * pricePerSeat).toFixed(2);
        }
    </script>
}
