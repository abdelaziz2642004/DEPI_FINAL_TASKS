@model CinemaBooking.ViewModels.MyBookingsViewModel
@{ ViewData["Title"] = "My Bookings"; }

<div class="container my-5">
    <h1 class="section-title mb-5">My Bookings</h1>

    <h4 class="fw-bold mb-3 text-white">Upcoming</h4>
    @if (Model.Upcoming.Any())
    {
        <div class="row g-3 mb-5">
            @foreach (var b in Model.Upcoming)
            {
                <div class="col-12 col-md-6">
                    <div class="card text-white p-3">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h6 class="fw-bold mb-0">@b.Showtime.Movie?.Title</h6>
                            <span class="badge bg-success">Confirmed</span>
                        </div>
                        <div class="text-muted small mb-1"><i class="bi bi-calendar me-1"></i>@b.Showtime.StartTime.ToLocalTime().ToString("ddd, MMM d · h:mm tt")</div>
                        <div class="text-muted small mb-1"><i class="bi bi-building me-1"></i>@b.Showtime.Hall?.Cinema?.Name — @b.Showtime.Hall?.Name</div>
                        <div class="text-muted small mb-3"><i class="bi bi-person me-1"></i>@b.NumberOfSeats seat(s)</div>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="fw-bold" style="color:var(--gold)">$@b.TotalPrice.ToString("F2")</span>
                            <form method="post" action="/Booking/Cancel" onsubmit="return confirm('Cancel this booking?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@b.Id" />
                                <button type="submit" class="btn btn-danger btn-sm">Cancel</button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <p class="text-muted mb-5">You have no upcoming bookings. <a href="/Movies" style="color:var(--gold)">Browse movies</a></p>
    }

    <h4 class="fw-bold mb-3 text-muted">Past Bookings</h4>
    @if (Model.Past.Any())
    {
        <div class="row g-3">
            @foreach (var b in Model.Past)
            {
                <div class="col-12 col-md-6">
                    <div class="card text-white p-3 opacity-75">
                        <div class="d-flex justify-content-between mb-2">
                            <h6 class="fw-bold mb-0">@b.Showtime.Movie?.Title</h6>
                            <span class="badge bg-secondary">Attended</span>
                        </div>
                        <div class="text-muted small mb-1"><i class="bi bi-calendar me-1"></i>@b.Showtime.StartTime.ToLocalTime().ToString("ddd, MMM d · h:mm tt")</div>
                        <div class="text-muted small mb-1"><i class="bi bi-building me-1"></i>@b.Showtime.Hall?.Cinema?.Name</div>
                        <div class="fw-bold mt-2" style="color:var(--gold)">$@b.TotalPrice.ToString("F2")</div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <p class="text-muted">No past bookings.</p>
    }
</div>
