@model CinemaBooking.ViewModels.LoginViewModel
@{ ViewData["Title"] = "Login"; }

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-5 col-lg-4">
            <div class="card text-white p-4">
                <h2 class="fw-bold mb-1">Welcome Back</h2>
                <p class="text-muted mb-4">Sign in to your CineMax account</p>
                <form method="post" action="/Account/Login">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
                    <div asp-validation-summary="All" class="alert alert-danger py-2 small mb-3" style="display:none"></div>
                    <div class="mb-3">
                        <label class="form-label fw-500">Email</label>
                        <input asp-for="Email" class="form-control bg-dark text-white border-secondary" placeholder="your@email.com" autocomplete="email" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-500">Password</label>
                        <input asp-for="Password" class="form-control bg-dark text-white border-secondary" placeholder="••••••••" autocomplete="current-password" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    <div class="mb-4 form-check">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label text-muted">Remember me</label>
                    </div>
                    <button type="submit" class="btn btn-gold w-100 py-2 fw-bold">Login</button>
                </form>
                <div class="text-center mt-3">
                    <span class="text-muted">Don't have an account? </span>
                    <a href="/Account/Register" style="color:var(--gold)">Sign up</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Show validation summary if it has errors
        const vs = document.querySelector('[data-valmsg-summary]');
        if (vs && vs.querySelector('li')) vs.style.display = '';
    </script>
}
