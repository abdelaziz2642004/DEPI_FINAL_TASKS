@model List<CinemaBooking.Models.Movie>
@{ ViewData["Title"] = "Movies"; }

<div class="container my-5">
    <h1 class="section-title mb-4">Movies</h1>

    <form method="get" class="row g-2 mb-4">
        <div class="col-12 col-md-5">
            <input type="text" name="search" class="form-control bg-dark text-white border-secondary" placeholder="Search by title..." value="@ViewBag.Search" />
        </div>
        <div class="col-12 col-md-4">
            <select name="categoryId" class="form-select bg-dark text-white border-secondary">
                <option value="">All Categories</option>
                @foreach (var c in (List<CinemaBooking.Models.Category>)ViewBag.Categories)
                {
                    <option value="@c.Id" selected="@(ViewBag.SelectedCategory?.ToString() == c.Id.ToString())">@c.Name</option>
                }
            </select>
        </div>
        <div class="col-auto">
            <button class="btn btn-gold" type="submit"><i class="bi bi-search me-1"></i>Filter</button>
        </div>
        <div class="col-auto">
            <a href="/Movies" class="btn btn-outline-secondary">Clear</a>
        </div>
    </form>

    <div class="row g-4">
        @foreach (var movie in Model)
        {
            <div class="col-6 col-sm-4 col-md-3">
                <div class="card h-100 text-white">
                    @if (movie.PosterPath != null)
                    {
                        <img src="@movie.PosterPath" class="poster-img" alt="@movie.Title" />
                    }
                    else
                    {
                        <div class="poster-placeholder"><i class="bi bi-film"></i></div>
                    }
                    <div class="card-body p-3">
                        <span class="badge badge-gold mb-2 small">@movie.Category?.Name</span>
                        <h6 class="card-title fw-bold mb-1">@movie.Title</h6>
                        <p class="text-muted small mb-3">@movie.DurationMinutes min · @movie.Language</p>
                        <a href="/Movies/Details/@movie.Id" class="btn btn-gold btn-sm w-100">View Showtimes</a>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-search fs-1 d-block mb-3"></i>
            <p>No movies found for your search.</p>
            <a href="/Movies" class="btn btn-outline-gold">Clear Filters</a>
        </div>
    }
</div>
