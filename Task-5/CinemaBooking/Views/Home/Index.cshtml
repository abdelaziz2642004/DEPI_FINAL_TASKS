@model List<CinemaBooking.Models.Movie>
@{ ViewData["Title"] = "Welcome to CineMax"; }

<section class="hero-section py-5" style="background: linear-gradient(135deg, #0d0d1a 0%, #1a1a35 50%, #0d1a2e 100%);">
    <div class="container py-4 text-center">
        <h1 class="display-4 fw-bold mb-3">
            <span style="color:var(--gold)">Experience</span> Cinema<br />Like Never Before
        </h1>
        <p class="lead text-muted mb-4">Book your tickets online — skip the queue, enjoy the show.</p>
        <a href="/Movies" class="btn btn-gold btn-lg px-5 me-2">Browse Movies</a>
        <a href="/Cinemas" class="btn btn-outline-gold btn-lg px-5">Our Cinemas</a>
    </div>
</section>

<div class="container my-5">
    <h2 class="section-title mb-4">Now Showing</h2>
    <div class="row g-4">
        @foreach (var movie in Model)
        {
            <div class="col-6 col-sm-4 col-md-3">
                <div class="card h-100 text-white">
                    @if (movie.PosterPath != null)
                    {
                        <img src="@movie.PosterPath" class="poster-img" alt="@movie.Title" />
                    }
                    else
                    {
                        <div class="poster-placeholder"><i class="bi bi-film"></i></div>
                    }
                    <div class="card-body p-3">
                        <span class="badge badge-gold mb-2 small">@movie.Category?.Name</span>
                        <h6 class="card-title fw-600 mb-1">@movie.Title</h6>
                        <p class="text-muted small mb-2">@movie.DurationMinutes min · @movie.Language</p>
                        <p class="small text-muted mb-3" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden">@movie.Description</p>
                        @{
                            var upcoming = movie.Showtimes?.Count(s => s.StartTime > DateTime.UtcNow) ?? 0;
                        }
                        @if (upcoming > 0)
                        {
                            <span class="badge bg-success mb-2">@upcoming showtime(s)</span>
                        }
                        <a href="/Movies/Details/@movie.Id" class="btn btn-gold btn-sm w-100">Book Tickets</a>
                    </div>
                </div>
            </div>
        }
    </div>
    @if (!Model.Any())
    {
        <div class="text-center text-muted py-5">
            <i class="bi bi-film fs-1 d-block mb-3"></i>
            <p>No movies available yet. Check back soon!</p>
        </div>
    }
</div>
