@model List<CinemaBooking.Models.Showtime>
@{
    ViewData["Title"] = "Manage Showtimes";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold text-white mb-0">All Showtimes</h5>
    <a href="/Admin/Showtimes/Create" class="btn btn-gold"><i class="bi bi-plus me-1"></i>Add Showtime</a>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-dark table-hover mb-0">
            <thead><tr><th>Movie</th><th>Cinema</th><th>Hall</th><th>Start Time</th><th>Price</th><th>Booked</th><th></th></tr></thead>
            <tbody>
                @foreach (var s in Model)
                {
                    <tr>
                        <td class="align-middle fw-500">@s.Movie?.Title</td>
                        <td class="align-middle text-muted">@s.Hall?.Cinema?.Name</td>
                        <td class="align-middle text-muted">@s.Hall?.Name</td>
                        <td class="align-middle">
                            @s.StartTime.ToLocalTime().ToString("MMM d, yyyy · h:mm tt")
                            @if (s.HasStarted) { <span class="badge bg-secondary ms-1 small">Past</span> }
                        </td>
                        <td class="align-middle" style="color:var(--gold)">$@s.TicketPrice.ToString("F2")</td>
                        <td class="align-middle text-muted">@s.Bookings?.Sum(b => b.NumberOfSeats) / @s.Hall?.SeatCapacity</td>
                        <td class="align-middle">
                            <a href="/Admin/Showtimes/Edit/@s.Id" class="btn btn-sm btn-outline-warning me-1">Edit</a>
                            <form method="post" action="/Admin/Showtimes/Delete" class="d-inline" onsubmit="return confirm('Delete showtime?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@s.Id" />
                                <button class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
