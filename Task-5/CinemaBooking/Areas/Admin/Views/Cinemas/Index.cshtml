@model List<CinemaBooking.Models.Cinema>
@{
    ViewData["Title"] = "Manage Cinemas";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold text-white mb-0">All Cinemas</h5>
    <a href="/Admin/Cinemas/Create" class="btn btn-gold"><i class="bi bi-plus me-1"></i>Add Cinema</a>
</div>

<div class="row g-4">
    @foreach (var c in Model)
    {
        <div class="col-md-6">
            <div class="card p-4">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <div>
                        <h6 class="fw-bold text-white mb-1">@c.Name</h6>
                        <p class="text-muted small mb-0">@c.Location</p>
                    </div>
                    <div class="d-flex gap-2">
                        <a href="/Admin/Cinemas/Edit/@c.Id" class="btn btn-sm btn-outline-warning">Edit</a>
                        <form method="post" action="/Admin/Cinemas/Delete" class="d-inline" onsubmit="return confirm('Delete cinema?')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@c.Id" />
                            <button class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    </div>
                </div>
                <div class="mt-3">
                    <span class="badge bg-secondary me-1">@c.Halls?.Count hall(s)</span>
                    <a href="/Admin/Halls?cinemaId=@c.Id" class="btn btn-sm btn-outline-info ms-2">
                        <i class="bi bi-door-open me-1"></i>Manage Halls
                    </a>
                </div>
            </div>
        </div>
    }
</div>
