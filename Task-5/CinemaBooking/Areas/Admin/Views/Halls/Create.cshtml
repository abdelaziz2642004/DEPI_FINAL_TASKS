@model CinemaBooking.ViewModels.HallFormViewModel
@{
    ViewData["Title"] = Model.Id == 0 ? "Add Hall" : "Edit Hall";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}
<div class="row justify-content-center">
    <div class="col-lg-5">
        <div class="card p-4">
            <p class="text-muted small mb-3">Cinema: <strong>@Model.CinemaName</strong></p>
            <form method="post" action="/Admin/Halls/@(Model.Id == 0 ? "Create" : "Edit")">
                @Html.AntiForgeryToken()
                @if (Model.Id != 0) { <input type="hidden" asp-for="Id" /> }
                <input type="hidden" asp-for="CinemaId" />
                <input type="hidden" asp-for="CinemaName" />
                <div class="mb-3">
                    <label class="form-label fw-500">Hall Name</label>
                    <input asp-for="Name" class="form-control" placeholder="e.g. Hall A" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                    <label class="form-label fw-500">Seat Capacity</label>
                    <input asp-for="SeatCapacity" type="number" class="form-control" />
                    <span asp-validation-for="SeatCapacity" class="text-danger small"></span>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-gold px-4">@(Model.Id == 0 ? "Create Hall" : "Save Changes")</button>
                    <a href="/Admin/Halls?cinemaId=@Model.CinemaId" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
